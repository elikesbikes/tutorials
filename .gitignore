# Exclude all .env files
.env
.env.*

# Exclude all CLAUDE.md files and .claude folders anywhere in the tree
CLAUDE.md
**/CLAUDE.md
.claude/
**/.claude/

# Exclude all hidden files/folders (starting with a dot)
.*
# But keep the .gitignore file itself!
!.gitignore
# Keep GitLab CI config
!.gitlab-ci.yml
# Runtime app data / model caches (bind-mounted, container-written)
openwebui_data/
*_data/
