# ==================================================
# RESTIC CONFIGURATION
# ==================================================
# Full path to the restic repository on the host (NFS mount)
RESTIC_REPOSITORY=/mnt/homenas/nfs_restic/nfs_<hostname>
RESTIC_PASSWORD=<your-strong-password>

# ==================================================
# NFS CONFIGURATION (host-side)
# ==================================================
NFS_SERVER=192.168.5.51
NFS_EXPORT=/mnt/PROD1/nfs_restic/nfs_<hostname>
MOUNT_POINT=/mnt/homenas/nfs_restic/nfs_<hostname>

# ==================================================
# NFS REACHABILITY
# ==================================================
PING_COUNT=2
PING_TIMEOUT=2

# ==================================================
# BEHAVIOUR FLAGS
# ==================================================
# Re-run NFS mount check after backup completes
RESTIC_POST_CHECK=true
# Unmount NFS after backup completes (true/false)
RESTIC_UNMOUNT_AFTER=true
